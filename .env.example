# Copie para `.env` e ajuste. O Create React App só expõe variáveis com prefixo REACT_APP_.

# Porta do dev server (npm start)
PORT=3001

# Base URL da API VendaLume-MS (sem barra no final).
# Deve incluir o path do backend, normalmente `/api`.
#
# Desenvolvimento com proxy em package.json apontando para o MS:
# REACT_APP_API_URL=/api
#
# Desenvolvimento sem proxy (configure CORS e cookies no MS):
# REACT_APP_API_URL=http://localhost:8080/api
#
# Produção:
# REACT_APP_API_URL=https://seu-dominio.com/api
REACT_APP_API_URL=/api

# Alias opcional (mesmo efeito que REACT_APP_API_URL; use só um dos dois):
# REACT_APP_API_BASE_URL=http://localhost:8080/api
